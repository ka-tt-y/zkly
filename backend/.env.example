# zkly backend configuration
PORT=3001
FRONTEND_URL=http://localhost:5173

# XeroStark API
XEROSTARK_API_URL=

# Storacha delegation
STORACHA_KEY=<base64-encoded-agent-private-key>
STORACHA_PROOF=<base64-encoded-ucan-delegation>
STORACHA_WALLET_HASH_SECRET=<stable-secret-for-app-owned-wallet-indexing>

# Starknet relayer wallet
STARKNET_RPC_URL=
STARKNET_RELAYER_ADDRESS=0x_your_relayer_address
STARKNET_RELAYER_PRIVATE_KEY=0x_your_relayer_private_key
